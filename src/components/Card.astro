---
import type { CollectionEntry } from "astro:content";
import { getPostUrl } from "@/utils/getPostPaths";
import { toTransitionName } from "@/utils/toTransitionName";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"posts">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, tags, ...props } = data;
---

<li class="list-none">
  <a
    href={getPostUrl(id, filePath, Astro.currentLocale)}
    class:list={[
      "group block h-full rounded-xl border border-border bg-muted/40 p-5",
      "transition-all duration-200",
      "hover:-translate-y-0.5 hover:border-accent/60 hover:bg-muted/70 hover:shadow-lg hover:shadow-accent/5",
      "focus-visible:border-accent",
    ]}
  >
    <Heading
      transition:name={toTransitionName(title)}
      class="text-base font-semibold leading-snug text-foreground transition-colors group-hover:text-accent sm:text-lg"
    >
      {title}
    </Heading>
    <div class="mt-1.5 text-xs text-muted-foreground">
      <Datetime {...props} />
    </div>
    <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-muted-foreground">
      {description}
    </p>
    {
      tags && tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {tags.slice(0, 3).map((tag: string) => (
            <span class="rounded-full border border-border bg-background/60 px-2 py-0.5 text-[11px] text-muted-foreground">
              #{tag}
            </span>
          ))}
        </div>
      )
    }
  </a>
</li>
