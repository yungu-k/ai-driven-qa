---
import { getEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

// About 콘텐츠의 단일 출처는 이 파일이다.
// src/content/pages/about.md 는 메타(title·description)만 제공한다.
const about = await getEntry("pages", "about");
if (!about) {
  throw new Error("Missing content entry: `about.md` in `src/content/pages/`");
}

const INTRO = [
  `<strong>공윤구</strong> — 10년차 QA 엔지니어입니다. 교육(해커스) → 핀테크(LINE Pay 대만) → 게임 플랫폼(넷마블) → 현재는 스타트업까지, 도메인이 바뀔 때마다 그 도메인의 품질 기준과 QA 프로세스를 새로 정의해 왔습니다.`,
  `지금은 글로벌 대형 카지노를 고객으로 하는 B2B 스타트업에서 현금·칩 거래 키오스크 제품의 QA를 전담합니다. 1인 QA로서 릴리스 트레인·QA 게이트·장애 대응 체계를 제로베이스에서 설계·운영했고, 지난 1년은 QA 업무 전반을 AI 협업 워크플로우로 전환하는 데 집중했습니다 — 반복 작업은 AI에게 위임하고 사람은 판단에 집중하는 구조를 만드는 일입니다. 이 블로그는 그 여정의 기록입니다.`,
];

const CONTACTS = [
  { label: "GitHub", href: "https://github.com/yungu-k" },
  { label: "LinkedIn", href: "https://www.linkedin.com/in/yungu-k/" },
];

const CHIPS = ["도메인 4개 전환", "1인 QA", "글로벌 고객 대응"];

const CAREER = [
  {
    company: "클로닉스",
    roles: [
      {
        title: "QA Engineer",
        period: "2025.07 ~ 현재",
        context:
          "글로벌 대형 카지노 대상 B2B 스타트업 — 현금·칩 거래 키오스크 제품군 QA 전담 (1인 QA). 금전을 다루는 규제 산업이라 정확성과 장애 대응이 특히 엄격한 환경입니다.",
        bullets: [
          `QA 프로세스 제로베이스 구축 — <a href="/posts/release-train-scrum/">2~3주 릴리스 트레인</a>, QA OK-Sign 게이트, 고객 대응 Incident 체계 설계·운영`,
          `<strong><a href="/posts/kiosk-automation-infra/">UI/API 이중 트랙 자동화 인프라</a> 구축</strong> — Playwright + vitest, 1,100건 green baseline`,
          `운영 알람 분류 자동화 → <strong><a href="/posts/realtime-kiosk-monitoring/">실시간 관제 대시보드</a></strong>(FastAPI+HTMX) 구축`,
          `외부 파트너용 <strong>기술지원 이력 시스템</strong>(Jira 양방향 동기화) 구축·운영 오픈`,
          `<strong><a href="/series/ai-teammate/">AI 팀원 3인(기획자·QA 엔지니어·개발자) 설계</a></strong> — 이 블로그의 주제. 전체 이야기는 <a href="/posts/repetition-to-ai-judgment-to-human/">QA 자동화 여정기</a>에`,
        ],
      },
    ],
  },
  {
    company: "넷마블",
    roles: [
      {
        title: "QA Part Lead (웹QA팀 파트장)",
        period: "2023.01 ~ 2024.04",
        bullets: [
          "QA 파트의 목표·전략 수립과 품질 지표 관리, 팀원 산출물(TC·리포트) 리뷰 총괄",
          "넷마블 자체결제·<strong>MBX 블록체인</strong> 등 신규 사업 QA 체계 구축",
          "외주 테스트 조직 운영 관리 — 업무 배분·품질 기준·산출물 검수",
        ],
      },
      {
        title: "QA Manager",
        period: "2020.08 ~ 2023.01",
        context:
          "전사 웹 플랫폼 5개 서비스(포럼·고객센터/백오피스·PC 런처·쿠폰·웹 결제) QA 담당.",
        bullets: [
          "서비스별 QA 프로세스 수립, 배포 Go/No-Go 게이트 운영 — 배포 제어와 릴리스 품질 책임",
          "Grafana 로그 모니터링 기반 장애 감지·대응, 장애 관리 프로세스 운영",
          "자동화 개발자와 협업해 장기 리그레션 자동화 운영, 중국 진출 등 글로벌 대응 QA",
        ],
      },
    ],
  },
  {
    company: "엔테크서비스",
    roles: [
      {
        title: "Test Engineer",
        period: "2018.10 ~ 2020.07",
        context: "대만 LINE Pay 결제 서비스 테스트 엔지니어.",
        bullets: [
          "대만 LINE Pay 오프라인 결제 앱 론칭 — 테스트 계획부터 배포 모니터링까지 전 주기",
          "<strong>대만-태국-일본 크로스보더 결제</strong> 구축 검증, iPASS(교통카드) 연동·Push 시스템 개편",
          "정기 배포 리그레션과 결함 리포팅 운영",
        ],
      },
    ],
  },
  {
    company: "해커스 교육그룹",
    roles: [
      {
        title: "QA",
        period: "2017.03 ~ 2018.09",
        bullets: [
          "<strong>10개 독립 사이트의 회원 통합 프로젝트</strong> 검증",
          "토익 학습 앱(Bigple) 론칭 — 회원가입·결제·동영상 강의 재생 TC 설계/수행",
        ],
      },
    ],
  },
];

const STRENGTHS = [
  {
    title: "프로세스를 만드는 QA",
    desc: "조직의 SDLC에 맞는 QA 프로세스를 수립·개선하고, 릴리스 체계와 배포 승인 게이트를 직접 설계합니다",
  },
  {
    title: "AI 업무 자동화(AX)",
    desc: "개별 도구가 아니라 일하는 방식의 전환. 규칙을 문서화하고, AI가 규격대로 산출하고, 사람이 검증·승인하는 구조를 QA 직무 전체에 적용했습니다",
  },
  {
    title: "도메인 전환력",
    desc: "교육 → 핀테크(결제) → 게임 플랫폼(블록체인 포함) → 규제 산업의 금전 거래 시스템까지, 도메인마다 품질 기준을 재정의",
  },
  {
    title: "경계를 넘는 커뮤니케이션",
    desc: "사업·기획·개발·운영 부서, 외주·해외 파트너와의 협업",
  },
];

const PRINCIPLES = [
  {
    title: "규칙은 코드가 아니라 문서에 먼저",
    desc: "사람도 읽고, AI도 참조하고, 신규 입사자도 이해한다",
  },
  {
    title: "실패는 규칙으로 옮긴다",
    desc: "같은 실수를 두 번 하지 않으려면 기억이 아니라 문서가 필요하다",
  },
  {
    title: "한계를 밝히면 신뢰가 올라간다",
    desc: "무엇을 보장하고 무엇을 보장하지 않는지를 함께 쓴다. 숫자만큼 중요한 건 그 숫자가 증명하지 않는 것의 목록이다",
  },
  {
    title: "자동화는 채택되어야 의미가 있다",
    desc: "도구를 만드는 것과 동료가 쓰는 것은 다른 문제다",
  },
];
---

<Layout
  title={`${about.data.title} | ${config.site.title}`}
  description={about.data.description}
  ogImage={about.data.ogImage}
  canonicalURL={about.data.canonicalURL}
>
  <Header />
  <Breadcrumb />

  <main id="main-content" class="app-layout pb-12">
    <!-- A1. 프로필 헤더 -->
    <section class="pt-6 pb-8">
      <div class="flex flex-wrap items-center gap-5">
        <div
          class="flex h-20 w-20 shrink-0 items-center justify-center rounded-full border border-accent/30 bg-accent/10 text-3xl font-extrabold text-accent"
          aria-hidden="true"
        >
          공
        </div>
        <div class="min-w-0">
          <h1 class="text-3xl font-extrabold tracking-tight">공윤구</h1>
          <p class="mt-1 text-sm text-muted-foreground">
            10년차 QA 엔지니어 · QA 프로세스 설계와 AI 업무 자동화(AX)
          </p>
          <div class="mt-3 flex flex-wrap items-center gap-2">
            {
              CONTACTS.map(({ label, href }) => (
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="rounded-lg border border-border bg-muted/40 px-3 py-1.5 text-xs font-semibold text-foreground transition-colors hover:border-accent/60 hover:text-accent"
                >
                  {label} ↗
                </a>
              ))
            }
            {
              CHIPS.map(chip => (
                <span class="rounded-full border border-border bg-background/60 px-2.5 py-1 text-[11px] text-muted-foreground">
                  {chip}
                </span>
              ))
            }
          </div>
        </div>
      </div>
      <div class="mt-6 space-y-3 max-w-3xl text-[15px] leading-relaxed">
        {INTRO.map(p => <p set:html={p} />)}
      </div>
    </section>

    <!-- A2. 경력 타임라인 -->
    <section class="pb-8">
      <h2 class="text-sm font-semibold tracking-widest text-muted-foreground uppercase">
        Career
      </h2>
      <div class="mt-4 space-y-4">
        {
          CAREER.map(({ company, roles }) => (
            <div class="rounded-xl border border-border bg-muted/40 p-5">
              <p class="text-base font-bold text-foreground">{company}</p>
              <div class="mt-3 space-y-5">
                {roles.map(role => (
                  <div class="border-l-2 border-accent/40 pl-4">
                    <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-0.5">
                      <p class="font-semibold text-foreground">{role.title}</p>
                      <p class="text-xs whitespace-nowrap text-muted-foreground">
                        {role.period}
                      </p>
                    </div>
                    {role.context && (
                      <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">
                        {role.context}
                      </p>
                    )}
                    <ul class="about-bullets mt-2 space-y-1.5 text-sm leading-relaxed">
                      {role.bullets.map(b => (
                        <li class="flex gap-2">
                          <span aria-hidden="true" class="mt-[2px] text-accent">
                            •
                          </span>
                          <span set:html={b} />
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- A3. 강점 / 원칙 카드 그리드 -->
    <section class="pb-8">
      <h2 class="text-sm font-semibold tracking-widest text-muted-foreground uppercase">
        강점
      </h2>
      <ul class="mt-4 grid gap-3 sm:grid-cols-2">
        {
          STRENGTHS.map(({ title, desc }) => (
            <li class="rounded-xl border border-border bg-muted/40 p-4">
              <p class="font-bold text-foreground">{title}</p>
              <p class="mt-1 text-sm leading-relaxed text-muted-foreground">
                {desc}
              </p>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="pb-8">
      <h2 class="text-sm font-semibold tracking-widest text-muted-foreground uppercase">
        일하는 원칙
      </h2>
      <ul class="mt-4 grid gap-3 sm:grid-cols-2">
        {
          PRINCIPLES.map(({ title, desc }) => (
            <li class="rounded-xl border border-border bg-muted/40 p-4">
              <p class="font-bold text-foreground">{title}</p>
              <p class="mt-1 text-sm leading-relaxed text-muted-foreground">
                {desc}
              </p>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- A4. 마무리 인용 배너 -->
    <section class="pb-4">
      <div
        class="rounded-r-xl border-l-4 border-accent bg-accent/5 px-6 py-5 text-lg font-bold tracking-tight"
      >
        반복은 <span class="text-accent">AI</span>에게, 판단은
        <span class="text-accent">사람</span>에게.
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .about-bullets :global(a) {
    color: var(--foreground);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--border);
  }
  .about-bullets :global(a:hover) {
    color: var(--accent);
  }
</style>
