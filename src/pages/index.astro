---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");

const stats = [
  { value: "10년차", label: "QA 엔지니어" },
  { value: "1,100+", label: "통과한 자동화 테스트" },
  { value: `${sortedPosts.length}편`, label: "실전 기록" },
  { value: "3인", label: "AI 팀원 (기획자·QA·개발자)" },
];
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="pt-12 pb-10 sm:pt-16">
      <p
        class="mb-3 inline-flex items-center gap-2 rounded-full border border-border bg-muted/50 px-3 py-1 text-xs font-medium tracking-wide text-muted-foreground"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent"></span>
        QA Engineer × AI Agent
      </p>
      <h1
        class="text-4xl leading-[1.15] font-extrabold tracking-tight sm:text-5xl"
      >
        반복은 <span class="text-accent">AI</span>에게,<br />
        판단은 <span class="text-accent">사람</span>에게
      </h1>
      <p
        class="mt-5 max-w-xl text-base leading-relaxed text-muted-foreground sm:text-lg"
      >
        TC 설계부터 실시간 운영 모니터링, AI 팀원 구축까지 — QA 업무 전체를 AI
        협업 워크플로우로 전환한 실전 기록을 남깁니다.
      </p>
      <div class="mt-5">
        <LinkButton
          href="/posts/repetition-to-ai-judgment-to-human/"
          class="text-accent font-semibold"
        >
          이 블로그를 관통하는 이야기
          <IconArrowRight class="inline-block transition-transform group-hover:translate-x-0.5 rtl:-rotate-180" />
        </LinkButton>
      </div>
      <div class="mt-6 flex items-center gap-4">
        {socials.length > 0 && <Socials />}
        <a
          target="_blank"
          href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
          class="inline-block"
          aria-label="RSS Feed"
          title="RSS Feed"
        >
          <IconRss width={18} height={18} class="stroke-muted-foreground hover:stroke-accent transition-colors" />
          <span class="sr-only">RSS Feed</span>
        </a>
      </div>
    </section>

    <section id="stats" class="pb-10">
      <ul class="grid grid-cols-2 gap-3 sm:grid-cols-4">
        {
          stats.map(({ value, label }) => (
            <li class="rounded-xl border border-border bg-muted/40 px-4 py-3">
              <p class="text-xl font-bold tracking-tight text-accent">
                {value}
              </p>
              <p class="mt-0.5 text-xs leading-snug text-muted-foreground">
                {label}
              </p>
            </li>
          ))
        }
      </ul>
    </section>

    {
      featuredPosts.length > 0 && (
        <section id="featured" class="pt-4 pb-8">
          <h2
            class="text-sm font-semibold tracking-widest text-muted-foreground uppercase"
          >
            {t.home.featured}
          </h2>
          <ul class="mt-4 grid gap-4 sm:grid-cols-2">
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-4 pb-6">
          <h2
            class="text-sm font-semibold tracking-widest text-muted-foreground uppercase"
          >
            {t.home.recentPosts}
          </h2>
          <ul class="mt-4 grid gap-4 sm:grid-cols-2">
            {recentPosts.slice(0, postsConfig.perIndex).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
